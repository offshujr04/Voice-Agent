{
  "manifest_version": 3,
  "name": "Voice Assistant (LiveKit) — Demo",
  "version": "0.1.0",
  "description": "Injects the LiveKit voice assistant widget on any website (works past strict CSP) for demos.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Voice Assistant settings",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
